DATABASE_URL=postgresql+psycopg://growth:growth@db:5432/growth_agent
APP_ENV=development
TESTING=false

# Generated by scripts/check_config.py when missing. Do not commit real values.
GROWTH_AGENT_API_KEY=

# Used by scripts and the Codex/ChatGPT MCP proxy server.
GROWTH_AGENT_BASE_URL=http://localhost:8000
GROWTH_AGENT_MCP_TIMEOUT_SECONDS=10

# Default is dry-run so Postiz is not called until explicitly disabled.
SCHEDULING_DRY_RUN=true

# Automation cycle defaults are safe: no live Postiz scheduling unless explicitly enabled.
AUTO_POSTING_ENABLED=false
AUTOMATION_KILL_SWITCH=false
MAX_AUTO_SCHEDULE_PER_CYCLE=1
MAX_AUTO_SCHEDULE_PER_DAY=3
MIN_HOURS_BETWEEN_AUTO_POSTS=4
DEFAULT_SCHEDULE_DELAY_MINUTES=30

# Postiz public API base URL. Include the full public API path; the app appends only /posts.
# Example: https://api.postiz.com/public/v1
POSTIZ_BASE_URL=
POSTIZ_API_KEY=
POSTIZ_X_INTEGRATION_ID=
TEST_X_ACCOUNT_HANDLE=

# Comma-separated domains that are allowed for lower-risk URL posts.
# Example: example.com,docs.example.com
OWNED_DOMAINS=
SAFE_PUBLIC_READS=false
AUTO_APPLY_TENTATIVE_RULES=false

# X API is read-only in this MVP: owned post lookup and metrics collection only.
X_API_BASE_URL=https://api.x.com
X_BEARER_TOKEN=
X_USER_ID=
X_RECONCILE_LOOKBACK_HOURS=48
X_RECONCILE_TEXT_SIMILARITY_THRESHOLD=0.82

REQUEST_TIMEOUT_SECONDS=10
MAX_EXTERNAL_RETRIES=2
DUPLICATE_SIMILARITY_THRESHOLD=0.88
AUTO_SCHEDULE_SCORE_THRESHOLD=80
